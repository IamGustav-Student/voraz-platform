# ====================================================
# BACKEND — Variables de Entorno
# Renombrar este archivo a: .env
# ====================================================

PORT=3000
NODE_ENV=development

# Base de datos (Docker local)
DB_USER=voraz_admin
DB_PASSWORD=voraz_password_secure
DB_HOST=localhost
DB_NAME=voraz_db
DB_PORT=5433

# JWT (cambiá este valor en producción)
JWGASTRORED_SUPERADMIN_SECRET=gastrored_super_secret
ADMIN_EMAIL=admin@tu-dominio.com

# MercadoPago (opcional — sin esto funciona en modo demo)
# MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx

# Google OAuth (opcional)
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# URLs (para callbacks de pago y OAuth)
# FRONTEND_URL=http://localhost:5173
# BACKEND_URL=http://localhost:3000
